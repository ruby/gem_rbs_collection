module Zip
  class Decompressor
    CHUNK_SIZE: Integer

    attr_reader decompressed_size: Integer?
    attr_reader input_stream: IO

    def self.register: (Integer compression_method, singleton(Decompressor) decompressor_class) -> void

    def self.find_by_compression_method: (Integer compression_method) -> singleton(Decompressor)?

    def initialize: (IO input_stream, ?Integer? decompressed_size) -> void

    def read: (?Integer? length, ?String outbuf) -> String?

    def eof?: -> bool
  end
end
