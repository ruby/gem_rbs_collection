module Zip
  class StreamableStream < Entry
    def initialize: (Entry entry) -> void

    def get_output_stream: ?{ (IO) -> void } -> IO

    def get_input_stream: ?{ (IO) -> void } -> IO

    def write_to_zip_output_stream: (OutputStream zip_output_stream) -> void

    def clean_up: -> void
  end
end
