module Zip
  module IOExtras
    module AbstractOutputStream
      include FakeIO

      def write: (String data) -> Integer

      def print: (*untyped params) -> void

      def printf: (String a_format_string, *untyped params) -> void

      def putc: (Integer | String an_object) -> void

      def puts: (*untyped params) -> void
    end
  end
end
