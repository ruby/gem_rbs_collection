module Zip
  class ExtraField
    class AES < ExtraField::Generic
      HEADER_ID: String

      attr_reader vendor_version: Integer?
      attr_reader vendor_id: String?
      attr_reader encryption_strength: Integer?
      attr_reader compression_method: Integer?

      def initialize: (?String? binstr) -> void

      def merge: (String binstr) -> void

      def suppress?: -> false

      def pack_for_local: -> String

      def pack_for_c_dir: -> String

      def ==: (untyped other) -> bool
    end
  end
end
