module Zip
  class ExtraField
    class Zip64 < ExtraField::Generic
      HEADER_ID: String

      attr_accessor original_size: Integer?
      attr_accessor compressed_size: Integer?
      attr_accessor relative_header_offset: Integer?
      attr_accessor disk_start_number: Integer?

      def initialize: (?String? binstr) -> void

      def merge: (String binstr) -> void

      def parse: (Entry base_entry) -> void

      def suppress?: -> bool

      def pack_for_local: -> String

      def pack_for_c_dir: -> String

      def ==: (untyped other) -> bool
    end
  end
end
