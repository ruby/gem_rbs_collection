module Ancestry
  module MaterializedPath[AncestryBaseClass, Relation, PrimaryKey]
    def path_of: (AncestryBaseClass | PrimaryKey object) -> Relation

    def roots: () -> Relation

    def ancestors_of: (AncestryBaseClass | PrimaryKey object) -> Relation

    def inpath_of: (AncestryBaseClass | PrimaryKey object) -> Relation

    def children_of: (AncestryBaseClass | PrimaryKey object) -> Relation

    def indirects_of: (AncestryBaseClass | PrimaryKey object) -> Relation

    def descendants_of: (AncestryBaseClass | PrimaryKey object) -> Relation

    def descendants_by_ancestry: (String ancestry) -> Arel::Nodes::Matches

    def descendant_conditions: (AncestryBaseClass | PrimaryKey object) -> Arel::Nodes::Matches

    def descendant_before_last_save_conditions: (AncestryBaseClass | PrimaryKey object) -> Arel::Nodes::Matches

    def subtree_of: (AncestryBaseClass | PrimaryKey object) -> Relation

    def siblings_of: (AncestryBaseClass | PrimaryKey object) -> Relation

    def ordered_by_ancestry: (?untyped? order) -> Relation

    def ordered_by_ancestry_and: (untyped? order) -> Relation

    def ancestry_root: () -> nil

    def child_ancestry_sql: () -> String

    def ancestry_depth_sql: () -> String

    def generate_ancestry: (Array[PrimaryKey]? ancestor_ids) -> String?

    def parse_ancestry_column: (String? obj) -> Array[PrimaryKey]

    def ancestry_depth_change: (String? old_value, String? new_value) -> Integer

    def concat: (*String args) -> String

    def self.generate: [T] (Array[T]? ancestor_ids, String delimiter, nil root) -> String?

    def self.parse: (String? obj, nil root, String delimiter, true integer_pk) -> Array[Integer]
                  | (String? obj, nil root, String delimiter, false integer_pk) -> Array[String]
                  | (String? obj, nil root, String delimiter, bool integer_pk) -> Array[Integer | String]

    def self.child_ancestry_value: [T] (String? ancestry_value, T id, String delimiter) -> String

    def self.descendants_condition: (Arel::Attributes::Attribute attr, String child_ancestry, String delimiter) -> Arel::Nodes::Matches

    def self.indirects_condition: (Arel::Attributes::Attribute attr, String child_ancestry, String delimiter) -> Arel::Nodes::Matches

    def self.concat: (String adapter, *String args) -> String

    def self.child_ancestry_sql: (String table_name, String | Symbol ancestry_column, String | Symbol primary_key, String delimiter, String adapter) -> String

    def self.construct_depth_sql: (String table_name, String | Symbol ancestry_column, String ancestry_delimiter) -> String

    def self.validation_options: ('[0-9]+' | '[-A-Fa-f0-9]{36}' primary_key_format, String delimiter) -> { format: { with: Regexp }, allow_nil: true }

    private

    def ancestry_validation_options: ('[0-9]+' | '[-A-Fa-f0-9]{36}' ancestry_primary_key_format) -> { format: { with: Regexp }, allow_nil: bool }

    module InstanceMethods[AncestryBaseClass, PrimaryKey]
      def ancestors?: () -> bool

      alias has_parent? ancestors?

      def ancestor_ids=: (Array[PrimaryKey]? value) -> void

      def ancestor_ids: () -> Array[PrimaryKey]

      def ancestor_ids_in_database: () -> Array[PrimaryKey]

      def ancestor_ids_before_last_save: () -> Array[PrimaryKey]

      def parent_id_in_database: () -> PrimaryKey?

      def parent_id_before_last_save: () -> PrimaryKey?

      def sibling_of?: (AncestryBaseClass node) -> bool

      def child_ancestry: () -> String

      def child_ancestry_before_last_save: () -> String
    end
  end
end
